{
  "_note": "金标向量：server pytest (tests/test_golden_vectors.py) 与 front .test-local-engine.mjs 共读，断言 Python/TS 逐值一致。改翻译协议（token 估算 / [[id]] 切块）必须两端同步并更新本文件。expected 由后端（权威源）生成。",
  "tokens": [
    { "text": "", "expected": 0 },
    { "text": "hello world", "expected": 3 },
    { "text": "你好，世界", "expected": 3 },
    { "text": "API token prompt commit", "expected": 6 },
    { "text": "混合 mixed 文本 text 123", "expected": 7 },
    { "text": "𠀀𠀁 surrogate pair", "expected": 5 },
    { "text": "导航 new→最新 submit→提交 past→往期", "expected": 10 },
    { "text": "a.b-c_d tail", "expected": 3 },
    { "text": "保留代码、标识符、以及中文技术圈惯用的英文术语（如 token、prompt、API、commit）原样不译。", "expected": 23 }
  ],
  "blockSplit": [
    {
      "name": "标记拆散到多chunk",
      "chunks": ["[", "[", "b", "1", "]", "]", " ", "你", "好", " ", "[", "[", "r", "2", ".", "b", "3", "0", "]", "]", " ", "w", "o", "r", "l", "d"],
      "expected": [["b1", "你好"], ["r2.b30", "world"]]
    },
    {
      "name": "单chunk两块",
      "chunks": ["[[a]]foo[[b]]bar"],
      "expected": [["a", "foo"], ["b", "bar"]]
    },
    {
      "name": "id含点和连字符",
      "chunks": ["[[r2.b30]] x ", "[[a-b_c]] y"],
      "expected": [["r2.b30", "x"], ["a-b_c", "y"]]
    },
    { "name": "无标记", "chunks": ["纯文本没有标记"], "expected": [] },
    {
      "name": "尾块靠flush",
      "chunks": ["[[only]] 最后一块不带后继"],
      "expected": [["only", "最后一块不带后继"]]
    }
  ],
  "_faultToleranceNote": "以下仅前端 block-splitter 的中档容错增强（归一化全角方括号 / 双括号夹空格），后端无此逻辑，故不参与双端对齐、只在 .test-local-engine.mjs 跑。",
  "blockSplitFaultTolerance": [
    {
      "name": "全角方括号",
      "chunks": ["［［a］］foo[[b]]bar"],
      "expected": [["a", "foo"], ["b", "bar"]]
    },
    {
      "name": "双括号夹空格",
      "chunks": ["[ [a] ] foo [ [b] ] bar"],
      "expected": [["a", "foo"], ["b", "bar"]]
    }
  ]
}
