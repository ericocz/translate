# 复制本文件为 .env。客户端只需后端基址；DeepSeek Key 已移到 server/.env（不再进扩展产物）。
WXT_BACKEND_URL=http://localhost:8000

# D-13 应用层加密：服务端静态公钥（base64）。留空＝明文路径（dev）。
# 生产填 server 的 `uv run python scripts/gen_session_keypair.py` 产出的公钥（公钥可公开）。
WXT_SERVER_PUBKEY=

# D-18 买断购买页（Creem 静态 payment link）。留空＝popup 不显示「买断」入口（dev）。
# 生产填 Creem 后台为 $9.99 买断商品生成的固定支付链接。
WXT_BUYOUT_URL=
